# =============================================================================
# Regulus AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.

# --- LLM Provider Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# --- Search / Fact-Checking (optional) ---
SERPAPI_KEY=
BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

# --- Lab Configuration ---
# LAB_DATABASE_PATH=data/lab.db
# LAB_MAX_CONCURRENT_TESTS=3
# LAB_DEFAULT_QUESTIONS_PER_TEAM=5
# LAB_BENCHMARK_CACHE_DIR=data/bbeh_cache
# LAB_RATE_LIMIT_RPM=60        # requests per minute (0 = disabled)
# LAB_RATE_LIMIT_BURST=10      # burst allowance above RPM

# --- API Server ---
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info
